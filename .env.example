# Port
PORT=3000

# --- GitHub --- #
# Fine-grained PAT: github.com/settings/personal-access-tokens/new
# Repository access: projects-wiki
# Permissions: Contents (Read and write), Metadata (Read)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=alpgiraykelem
GITHUB_REPO=projects-wiki
GITHUB_BRANCH=main

# --- Commit yazarı --- #
COMMIT_AUTHOR_NAME=Claude MCP
COMMIT_AUTHOR_EMAIL=claude-mcp@users.noreply.github.com

# --- Auth: Static Bearer (Claude Desktop / mcp-remote) --- #
# openssl rand -hex 32 ile üret. OAuth kullanacaksan boş bırakabilirsin.
MCP_BEARER_TOKEN=change-me-openssl-rand-hex-32

# --- Auth: OAuth 2.1 (Claude.ai web + mobil için ZORUNLU) --- #
# Deploy URL'in (Coolify'ın vereceği HTTPS endpoint)
PUBLIC_URL=https://mcp.alpgiraykelem.com
# /authorize onay formundaki master password.
# openssl rand -base64 24 ile üret — telefonda yazman gerekecek, çok uzun olmasın.
OWNER_PASSWORD=change-me-to-strong-password
